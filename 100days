-- Variables
local collectedItems = {}
local isCollecting = false

-- Find DebrisField
local function getDebrisField()
    local debrisField = workspace:FindFirstChild("DebrisField")
    if not debrisField then
        StatusLabel.Text = "❌ DebrisField not found!"
        return nil
    end
    return debrisField
end

-- Get all items in DebrisField
local function getDebrisItems()
    local debrisField = getDebrisField()
    if not debrisField then return {} end
    
    local items = {}
    for _, child in pairs(debrisField:GetChildren()) do
        if child:IsA("BasePart") or child:IsA("Model") then
            table.insert(items, child)
        end
    end
    return items
end

-- Update item count display
local function updateCount()
    local items = getDebrisItems()
    CountLabel.Text = "Items: " .. #items
    return #items
end

-- Teleport a single item to the player
local function teleportItemToPlayer(item, targetPosition)
    if not item or not item.Parent then return false end
    
    local success, err = pcall(function()
        if item:IsA("Model") and item.PrimaryPart then
            local offset = item.PrimaryPart.CFrame - item.PrimaryPart.CFrame.Position
            item:SetPrimaryPartCFrame(CFrame.new(targetPosition) * offset)
        elseif item:IsA("BasePart") then
            item.CFrame = CFrame.new(targetPosition)
        else
            return false
        end
    end)
    
    return success
end

-- Animate item coming to player with tween
local function animateItemToPlayer(item, targetPosition)
    if not item or not item.Parent then return false end
    
    local success, err = pcall(function()
        local startCFrame
        local offset = CFrame.new()
        
        if item:IsA("Model") and item.PrimaryPart then
            startCFrame = item.PrimaryPart.CFrame
            offset = startCFrame - startCFrame.Position
        elseif item:IsA("BasePart") then
            startCFrame = item.CFrame
        else
            return false
        end
        
        local endCFrame = CFrame.new(targetPosition) * (offset or CFrame.new())
        
        if item:IsA("Model") and item.PrimaryPart then
            local tweenInfo = TweenInfo.new(
                0.5 + math.random() * 0.3,
                Enum.EasingStyle.Quad,
                Enum.EasingDirection.Out
            )
            
            local tween = TweenService:Create(item.PrimaryPart, tweenInfo, {
                CFrame = endCFrame
            })
            tween:Play()
            tween.Completed:Wait()
        elseif item:IsA("BasePart") then
            local tweenInfo = TweenInfo.new(
                0.5 + math.random() * 0.3,
                Enum.EasingStyle.Quad,
                Enum.EasingDirection.Out
            )
            
            local tween = TweenService:Create(item, tweenInfo, {
                CFrame = endCFrame
            })
            tween:Play()
            tween.Completed:Wait()
        end
    end)
    
    return success
end

-- Main collection function
local function collectAllItems(animate)
    if isCollecting then
        StatusLabel.Text = "⏳ Already collecting..."
        return
    end
    
    local character = LocalPlayer.Character
    if not character then
        StatusLabel.Text = "❌ No character found!"
        return
    end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then
        StatusLabel.Text = "❌ No HumanoidRootPart!"
        return
    end
    
    local debrisField = getDebrisField()
    if not debrisField then return end
    
    local items = getDebrisItems()
    if #items == 0 then
        StatusLabel.Text = "✅ No items to collect!"
        return
    end
    
    isCollecting = true
    CollectButton.Text = "⏳ COLLECTING..."
    CollectButton.BackgroundColor3 = Color3.fromRGB(150, 150, 0)
    StatusLabel.Text = "🔄 Collecting " .. #items .. " items..."
    
    local collected = 0
    local failed = 0
    local targetPos = humanoidRootPart.Position + Vector3.new(0, 2, 0)
    
    local function getRandomOffset(index)
        local angle = index * 1.2
        local radius = 1 + (index % 3) * 0.8
        return Vector3.new(
            math.cos(angle) * radius,
            (index % 2) * 0.5,
            math.sin(angle) * radius
        )
    end
    
    for i, item in pairs(items) do
        if not item or not item.Parent then
            failed = failed + 1
            goto continue
        end
        
        local offset = getRandomOffset(i)
        local itemPos = targetPos + offset
        
        local success
        if animate then
            success = animateItemToPlayer(item, itemPos)
        else
            success = teleportItemToPlayer(item, itemPos)
        end
        
        if success then
            collected = collected + 1
            table.insert(collectedItems, item)
        else
            failed = failed + 1
        end
        
        if i % 5 == 0 then
            StatusLabel.Text = "🔄 Collected " .. collected .. "/" .. #items
        end
        
        ::continue::
    end
    
    isCollecting = false
    CollectButton.Text = "🔄 COLLECT ALL"
    CollectButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    
    local remaining = #getDebrisItems()
    StatusLabel.Text = "✅ Collected " .. collected .. " items (" .. failed .. " failed, " .. remaining .. " remaining)"
    CountLabel.Text = "Items: " .. remaining
    
    if collected > 0 then
        print("[DebrisCollector] Successfully collected " .. collected .. " items!")
    end
end

CollectButton.MouseButton1Click:Connect(function()
    collectAllItems(true)
end)

TeleportButton.MouseButton1Click:Connect(function()
    collectAllItems(false)
end)

local function startAutoUpdate()
    RunService.Heartbeat:Connect(function()
        if not isCollecting then
            updateCount()
        end
    end)
end

local function init()
    local debrisField = getDebrisField()
    if debrisField then
        StatusLabel.Text = "✅ DebrisField found!"
        local count = updateCount()
        print("[DebrisCollector] Found " .. count .. " items in DebrisField")
    else
        StatusLabel.Text = "❌ DebrisField not found!"
    end
    
    startAutoUpdate()
end

ScreenGui.AncestryChanged:Connect(function()
    if not ScreenGui.Parent then
        collectedItems = nil
    end
end)

init()

local UserInputService = game:GetService("UserInputService")
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.C then
        collectAllItems(true)
    elseif input.KeyCode == Enum.KeyCode.T then
        collectAllItems(false)
    end
end)

print("[DebrisCollector] Loaded! Press 'C' to collect with animation, 'T' to teleport instantly")
